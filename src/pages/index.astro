---
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../utils/base";

const repoUrl = "https://github.com/Elli2022/kriminalvarden-concept-site";

const gallery = [
  {
    src: "/legacy/images/kriminalvarden/project_kriminalvarden_big_picture.jpg",
    alt: "Huvudbild från det ursprungliga Kriminalvarden-konceptet.",
  },
  {
    src: "/legacy/images/kriminalvarden/project_kriminalvarden_small_picture_1_section_5.1.png",
    alt: "Första detaljbilden från det ursprungliga konceptet.",
  },
  {
    src: "/legacy/images/kriminalvarden/project_kriminalvarden_small_picture_2_section_5.2.png",
    alt: "Andra detaljbilden från det ursprungliga konceptet.",
  },
  {
    src: "/legacy/images/kriminalvarden/project_kriminalvarden_small_picture_3_section_5.3.png",
    alt: "Tredje detaljbilden från det ursprungliga konceptet.",
  },
];
---

<BaseLayout
  title="Kriminalvarden"
  description="Ett fristående hem för Kriminalvarden-konceptet, moderniserat till en lättskött statisk sajt med den ursprungliga sidan bevarad under /legacy/."
>
  <header class="topbar">
    <a class="wordmark" href={withBase("/")}>Kriminalvarden</a>
    <nav aria-label="Primary navigation">
      <a href="#context">Kontext</a>
      <a href="#gallery">Galleri</a>
      <a href="#archive">Legacy</a>
    </nav>
  </header>

  <main id="main-content" class="page-shell">
    <section class="hero">
      <div class="hero__copy">
        <p class="eyebrow">Standalone archive rebuild</p>
        <h1>Ett eget repo för Kriminalvarden-konceptet.</h1>
        <p class="lead">
          Den här versionen bryter ut den gamla portfoliosidan till en egen statisk sajt. Målet är
          inte att skriva om historien, utan att ge projektet en tydligare identitet, bättre
          struktur och en långsiktigt hållbar deploy.
        </p>
        <div class="actions">
          <a class="button button--primary" href={withBase("/legacy/html/kriminalvarden.html")}>
            Öppna originalet
          </a>
          <a class="button button--ghost" href={repoUrl} target="_blank" rel="noreferrer">
            GitHub-repo
          </a>
        </div>
      </div>

      <div class="hero__panel">
        <p class="eyebrow">Vad som ändrats</p>
        <ul>
          <li>Konceptet har fått ett fristående hem i stället för att ligga gömt i en större portfolio.</li>
          <li>Huvudsidan är nu snabb, statisk och byggd för enkel publicering via GitHub Pages.</li>
          <li>Originalsidan finns kvar under <code>/legacy/</code> för framtida återbesök.</li>
        </ul>
      </div>
    </section>

    <section class="info-grid" id="context">
      <article class="card">
        <p class="eyebrow">Projektkontext</p>
        <h2>Utgångspunkt</h2>
        <p>
          Ursprungsversionen presenterade projektet kort som <em>Private Project - KVV</em> med
          fokus på bildyta och visuella nedslag. Den här nya versionen samlar samma material men
          ramar in det tydligare som ett arkiverat koncept från 2022.
        </p>
      </article>

      <article class="card">
        <p class="eyebrow">Modernisering</p>
        <h2>Varför eget repo</h2>
        <p>
          När ett enskilt case får ett eget repo blir det lättare att deploya, dokumentera och
          vidareutveckla utan att påverka resten av portfolion. Det gör också projektets lineage
          tydligare på GitHub.
        </p>
      </article>

      <article class="card">
        <p class="eyebrow">Teknisk riktning</p>
        <h2>Best fit stack</h2>
        <p>
          Astro passar bäst här eftersom sajten är innehållsdriven och helt statisk. Det ger en
          lätt struktur, enkel build-process och ingen onödig runtime i webbläsaren.
        </p>
      </article>
    </section>

    <section class="gallery" id="gallery">
      <div class="section-heading">
        <p class="eyebrow">Visuellt material</p>
        <h2>Originalbilderna lever vidare utan att fastna i den gamla strukturen.</h2>
      </div>

      <div class="gallery__grid">
        {
          gallery.map((image) => (
            <figure class="gallery__item">
              <img src={withBase(image.src)} alt={image.alt} loading="lazy" decoding="async" />
            </figure>
          ))
        }
      </div>
    </section>

    <section class="archive-band" id="archive">
      <div>
        <p class="eyebrow">Legacy route</p>
        <h2>Originalsidan finns kvar som ett besökbart arkiv.</h2>
        <p>
          Om du vill se projektet precis som det presenterades i den äldre portfolion finns den
          fortfarande kvar här, med enkel hjälpnavigering runt omkring så att inga länkar dör i
          utbrytningen.
        </p>
      </div>

      <a class="button button--primary" href={withBase("/legacy/html/kriminalvarden.html")}>
        Till legacy-sidan
      </a>
    </section>
  </main>
</BaseLayout>
